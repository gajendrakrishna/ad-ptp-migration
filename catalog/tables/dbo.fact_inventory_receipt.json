  "scoping": {
    "table": "dbo.fact_inventory_receipt",
    "selected_writer": "etl.usp_load_fact_inventory_receipt",
    "status": "resolved",
    "writer_analysis": {
      "procedure": "etl.usp_load_fact_inventory_receipt",
      "write_type": "direct",
      "pattern": "truncate_insert",
      "sources": [
        "PTP_System.Purchasing.GoodsReceiptLines",
        "PTP_System.Purchasing.GoodsReceipts",
        "PTP_System.Purchasing.PurchaseOrderLines",
        "PTP_System.Purchasing.PurchaseOrders",
        "PTP_System.Master.Vendors",
        "PTP_System.Master.Items",
        "PTP_System.Master.Employees"
      ],
      "dimension_lookups": [
        "dbo.Dim_Date",
        "dbo.Dim_Vendor",
        "dbo.Dim_Product",
        "dbo.Dim_Employee",
        "dbo.Dim_Location"
      ],
      "statements": [
        {
          "type": "TRUNCATE",
          "action": "skip",
          "note": "Handled by dbt full-refresh"
        },
        {
          "type": "INSERT",
          "action": "migrate",
          "note": "Core transformation logic — all non-identity columns populated via CTE + main SELECT"
        }
      ],
      "logic_summary": "Full reload via TRUNCATE + INSERT. CTE (GR_RunningTotal) computes per-PO-line running cumulative received quantity using SUM OVER window function ordered by ReceiptDate/GRID/GRLineID, filtered to Posted receipts. Main SELECT joins goods receipts, PO lines/headers, vendors, items, employees from PTP_System and resolves surrogate keys against DW dimensions with ISNULL defaults. Key derived measures: Lead_Time_Days (DATEDIFF PODate to ReceiptDate), Delivery_Variance_Days (DATEDIFF ExpectedDelivery to ReceiptDate, nullable when no expected date), Receipt_Completeness_Pct (cumulative/ordered*100), Quantity_Outstanding. Location surrogate resolved via rule-based CASE on ItemCategory (Office→WH-SUPP-03, Hardware SWITCH→WH-NET-04, Hardware→WH-IT-02, else WH-CORP-01)."
    },
    "warnings": []
  },
  "profile": {
    "status": "ok",
    "writer": "etl.usp_load_fact_inventory_receipt",
    "classification": {
      "resolved_kind": "fact_accumulating_snapshot",
      "source": "llm",
      "rationale": "The table tracks the accumulating fulfillment state of each goods receipt line against its PO line, storing cumulative measures (Cumulative_Qty_Received, Quantity_Outstanding, Receipt_Completeness_Pct) that evolve as more receipts arrive. Although implemented as a TRUNCATE + full reload, the semantic grain and measure design match an accumulating snapshot tracking progress of a multi-step business process (PO to receipts to fulfilment) over time."
    },
    "primary_key": {
      "columns": [
        "Fact_Receipt_SK"
      ],
      "primary_key_type": "surrogate",
      "source": "catalog",
      "rationale": "Catalog declares PK_Fact_Receipt on Fact_Receipt_SK, which is an IDENTITY BIGINT column — a definitive surrogate key confirmed by both the primary_keys and auto_increment_columns catalog signals."
    },
    "natural_key": {
      "columns": [
        "GR_BK",
        "Product_SK"
      ],
      "source": "llm",
      "rationale": "Fact_Receipt_SK is an identity surrogate; the natural grain identifier is the goods receipt number (GR_BK) combined with the product (Product_SK), representing one receipt line per product per GR event, as the source system GRLineID is not persisted in the fact table."
    },
    "watermark": {
      "column": "DW_Load_DateTime",
      "source": "llm",
      "rationale": "The proc performs a full TRUNCATE + reload with no incremental WHERE clause; DW_Load_DateTime (DATETIME2 NOT NULL) is the only datetime column on the fact table itself and serves as the dbt incremental watermark. Recommended dbt strategy: microbatch or merge."
    },
