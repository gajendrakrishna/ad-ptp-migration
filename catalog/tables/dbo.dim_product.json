  "scoping": {
    "status": "resolved",
    "selected_writer": "etl.usp_load_dim_product",
    "selected_writer_rationale": "etl.usp_load_dim_product is the sole direct writer to dbo.Dim_Product, implementing SCD Type 2 via a two-phase UPDATE+INSERT pattern. All four other procedures that reference Dim_Product (usp_load_fact_ap_invoice, usp_load_fact_inventory_receipt, usp_load_fact_po, usp_load_fact_requisition) are read-only consumers joining on Product_BK/IsCurrent."
  },
  "profile": {
    "status": "ok",
    "writer": "etl.usp_load_dim_product",
    "classification": {
      "resolved_kind": "dim_scd2",
      "source": "llm",
      "rationale": "The writer proc implements a two-phase expire+reinsert pattern: Phase 1 sets IsCurrent=0 and EffectiveEnd=today-1 for hash-changed rows; Phase 2 inserts new versions with IsCurrent=1 and EffectiveEnd='9999-12-31'. Column shape confirms SCD2: EffectiveStart, EffectiveEnd, IsCurrent, and a surrogate PK alongside a separate business key Product_BK."
    },
    "primary_key": {
      "columns": [
        "Product_SK"
      ],
      "primary_key_type": "surrogate",
      "source": "catalog",
      "rationale": "Catalog declares PK_Dim_Product on Product_SK, and auto_increment_columns confirms Product_SK is an identity column — a definitive surrogate key signal."
    },
    "natural_key": {
      "columns": [
        "Product_BK"
      ],
      "source": "llm",
      "rationale": "Product_BK is used as the match column in both proc phases: the expire UPDATE joins on dw.Product_BK = src.ItemCode, and the insert NOT EXISTS guard filters on dw.Product_BK = src.ItemCode, establishing it as the business key."
    },
    "watermark": {
      "column": null,
      "source": "llm",
      "rationale": "The proc performs a full-scan load each run with no date-based WHERE filter on the source. Change detection is hash-based (SourceRowHash). DW_InsertDate is a DW metadata column, not a source modification watermark. This translates to a dbt snapshot with check strategy."
    },
    "foreign_keys": [],
    "pii_actions": []
  },
  "refactor": {
    "status": "ok",
    "extracted_sql": "SELECT src.ItemCode AS Product_BK, src.ItemName AS ProductName, ISNULL(src.Description, '') AS Description, src.UnitOfMeasure, src.ItemCategory AS Category, src.AccountingType, ISNULL(src.GLAccount, '00000') AS GLAccount, CAST(GETDATE() AS DATE) AS EffectiveStart, CAST('9999-12-31' AS DATE) AS EffectiveEnd, CAST(1 AS BIT) AS IsCurrent, CAST(SYSUTCDATETIME() AS DATETIME2(0)) AS DW_InsertDate, HASHBYTES('SHA2_256', CONCAT_WS('|', src.ItemName, ISNULL(src.Description, ''), src.UnitOfMeasure, src.ItemCategory, src.AccountingType, ISNULL(src.GLAccount, ''))) AS SourceRowHash FROM [PTP_System].[Master].[Items] src WHERE NOT EXISTS ( SELECT 1 FROM [dbo].[Dim_Product] dw WHERE dw.Product_BK = src.ItemCode AND dw.IsCurrent = 1 )",
    "refactored_sql": "WITH source_items AS ( SELECT * FROM [PTP_System].[Master].[Items] ), existing_current AS ( SELECT Product_BK FROM [dbo].[Dim_Product] WHERE IsCurrent = 1 ), new_versions AS ( SELECT src.ItemCode AS Product_BK, src.ItemName AS ProductName, ISNULL(src.Description, '') AS Description, src.UnitOfMeasure, src.ItemCategory AS Category, src.AccountingType, ISNULL(src.GLAccount, '00000') AS GLAccount, CAST(GETDATE() AS DATE) AS EffectiveStart, CAST('9999-12-31' AS DATE) AS EffectiveEnd, CAST(1 AS BIT) AS IsCurrent, CAST(SYSUTCDATETIME() AS DATETIME2(0)) AS DW_InsertDate, HASHBYTES('SHA2_256', CONCAT_WS('|', src.ItemName, ISNULL(src.Description, ''), src.UnitOfMeasure, src.ItemCategory, src.AccountingType, ISNULL(src.GLAccount, ''))) AS SourceRowHash FROM source_items src WHERE NOT EXISTS ( SELECT 1 FROM existing_current dw WHERE dw.Product_BK = src.ItemCode ) ), final AS ( SELECT * FROM new_versions ) SELECT * FROM final"
  }
}
