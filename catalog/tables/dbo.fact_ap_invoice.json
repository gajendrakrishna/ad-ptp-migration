    "key_transformations": [
      "Price_Variance = (InvoicedUnitPrice - AgreedUnitPrice) * QuantityBilled",
      "Price_Variance_Pct: NULL-safe percentage variance (NULL when AgreedUnitPrice = 0)",
      "Days_Until_Due = DATEDIFF(DAY, InvoiceDate, DueDate)",
      "Days_Invoice_To_Receive = DATEDIFF(DAY, InvoiceDate, ReceivedDate)",
      "Is_Match_Passed: derived from MatchStatus = 'Matched'",
      "Is_Disputed: derived from InvoiceStatus = 'Disputed'",
      "Is_Paid: derived from InvoiceStatus = 'Paid'"
    ],
    "notes": "Truncate-insert full-refresh pattern. Sources from PTP_System transactional tables; resolves surrogate keys via Dim_Date (yyyyMMdd INT cast), Dim_Vendor and Dim_Product (IsCurrent=1 lookup)."
  },
