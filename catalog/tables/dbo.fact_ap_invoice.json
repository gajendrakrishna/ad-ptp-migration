        "description": "Full-refresh truncate before reload",
        "disposition": "migrate"
      },
      {
        "type": "INSERT",
        "target": "dbo.fact_ap_invoice",
        "description": "Core transformation: joins invoice/line/PO source tables, resolves conformed dim SKs, derives price variance measures and boolean status flags",
        "disposition": "migrate"
      },
      {
        "type": "PRINT",
        "target": null,
        "description": "Diagnostic row-count message",
        "disposition": "skip"
      }
