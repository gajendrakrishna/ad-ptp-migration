  "refactor": {
    "status": "ok",
    "extracted_sql": "SELECT inv.InternalInvoiceRef AS Invoice_BK, inv.InvoiceNumber AS Vendor_Invoice_Number, il.LineNumber AS Invoice_Line_Number, po.PONumber AS PO_BK, -- Date keys ISNULL(d_inv.Date_SK, 0) AS InvoiceDate_SK, ISNULL(d_rcv.Date_SK, 0) AS ReceivedDate_SK, ISNULL(d_due.Date_SK, 0) AS DueDate_SK, -- Conformed dimensions ISNULL(vnd.Vendor_SK, -1) AS Vendor_SK, ISNULL(prod.Product_SK,-1) AS Product_SK, -- AP match flags inv.InvoiceStatus AS Invoice_Status, inv.MatchStatus AS Match_Status, CASE WHEN inv.MatchStatus = 'Matched' THEN 1 ELSE 0 END AS Is_Match_Passed, CASE WHEN inv.InvoiceStatus = 'Disputed' THEN 1 ELSE 0 END AS Is_Disputed, CASE WHEN inv.InvoiceStatus = 'Paid' THEN 1 ELSE 0 END AS Is_Paid, -- Billing quantities and prices il.QuantityBilled AS Quantity_Billed, il.InvoicedUnitPrice AS Invoiced_Unit_Price, pol.AgreedUnitPrice AS PO_Unit_Price, CAST(il.QuantityBilled * il.InvoicedUnitPrice AS DECIMAL(18,2)) AS Invoice_Line_Total, CAST(il.QuantityBilled * pol.AgreedUnitPrice AS DECIMAL(18,2)) AS PO_Line_Amount, -- Price variance CAST((il.InvoicedUnitPrice - pol.AgreedUnitPrice) * il.QuantityBilled AS DECIMAL(18,2)) AS Price_Variance, -- Percentage variance (NULL-safe: no division by zero) CASE WHEN pol.AgreedUnitPrice <> 0 THEN CAST(((il.InvoicedUnitPrice - pol.AgreedUnitPrice) / pol.AgreedUnitPrice) * 100 AS DECIMAL(8,4)) ELSE NULL END AS Price_Variance_Pct, -- AP urgency KPI DATEDIFF(DAY, inv.InvoiceDate, inv.DueDate) AS Days_Until_Due, -- AP processing lag DATEDIFF(DAY, inv.InvoiceDate, inv.ReceivedDate) AS Days_Invoice_To_Receive FROM [PTP_System].[Finance].[Invoices] inv INNER JOIN [PTP_System].[Finance].[InvoiceLines] il ON il.InvoiceID = inv.InvoiceID INNER JOIN [PTP_System].[Purchasing].[PurchaseOrderLines] pol ON pol.POLineID = il.POLineID INNER JOIN [PTP_System].[Purchasing].[PurchaseOrders] po ON po.POID = pol.POID INNER JOIN [PTP_System].[Master].[Vendors] src_vnd ON src_vnd.VendorID = inv.VendorID INNER JOIN [PTP_System].[Master].[Items] src_itm ON src_itm.ItemID = il.ItemID -- Date lookups LEFT JOIN [dbo].[Dim_Date] d_inv ON d_inv.Date_SK = CAST(FORMAT(inv.InvoiceDate, 'yyyyMMdd') AS INT) LEFT JOIN [dbo].[Dim_Date] d_rcv ON d_rcv.Date_SK = CAST(FORMAT(inv.ReceivedDate, 'yyyyMMdd') AS INT) LEFT JOIN [dbo].[Dim_Date] d_due ON d_due.Date_SK = CAST(FORMAT(inv.DueDate, 'yyyyMMdd') AS INT) -- Conformed dim lookups (current version) LEFT JOIN [dbo].[Dim_Vendor] vnd ON vnd.Vendor_BK = src_vnd.VendorCode AND vnd.IsCurrent = 1 LEFT JOIN [dbo].[Dim_Product] prod ON prod.Product_BK = src_itm.ItemCode AND prod.IsCurrent = 1",
    "refactored_sql": "WITH -- Import CTEs: one per source table source_invoices AS ( SELECT * FROM [PTP_System].[Finance].[Invoices] ), source_invoice_lines AS ( SELECT * FROM [PTP_System].[Finance].[InvoiceLines] ), source_po_lines AS ( SELECT * FROM [PTP_System].[Purchasing].[PurchaseOrderLines] ), source_purchase_orders AS ( SELECT * FROM [PTP_System].[Purchasing].[PurchaseOrders] ), source_vendors AS ( SELECT * FROM [PTP_System].[Master].[Vendors] ), source_items AS ( SELECT * FROM [PTP_System].[Master].[Items] ), dim_date AS ( SELECT * FROM [dbo].[Dim_Date] ), dim_vendor AS ( SELECT * FROM [dbo].[Dim_Vendor] ), dim_product AS ( SELECT * FROM [dbo].[Dim_Product] ), -- Logical CTE: join source transactional tables invoice_lines_joined AS ( SELECT inv.InvoiceID, inv.InternalInvoiceRef, inv.InvoiceNumber, inv.VendorID, inv.InvoiceDate, inv.ReceivedDate, inv.DueDate, inv.InvoiceStatus, inv.MatchStatus, il.LineNumber, il.POLineID, il.ItemID, il.QuantityBilled, il.InvoicedUnitPrice, pol.AgreedUnitPrice, po.PONumber, src_vnd.VendorCode, src_itm.ItemCode FROM source_invoices inv INNER JOIN source_invoice_lines il ON il.InvoiceID = inv.InvoiceID INNER JOIN source_po_lines pol ON pol.POLineID = il.POLineID INNER JOIN source_purchase_orders po ON po.POID = pol.POID INNER JOIN source_vendors src_vnd ON src_vnd.VendorID = inv.VendorID INNER JOIN source_items src_itm ON src_itm.ItemID = il.ItemID ), -- Logical CTE: resolve conformed dimension surrogate keys with_dimension_keys AS ( SELECT ilj.*, ISNULL(d_inv.Date_SK, 0) AS InvoiceDate_SK, ISNULL(d_rcv.Date_SK, 0) AS ReceivedDate_SK, ISNULL(d_due.Date_SK, 0) AS DueDate_SK, ISNULL(vnd.Vendor_SK, -1) AS Vendor_SK, ISNULL(prod.Product_SK, -1) AS Product_SK FROM invoice_lines_joined ilj LEFT JOIN dim_date d_inv ON d_inv.Date_SK = CAST(FORMAT(ilj.InvoiceDate, 'yyyyMMdd') AS INT) LEFT JOIN dim_date d_rcv ON d_rcv.Date_SK = CAST(FORMAT(ilj.ReceivedDate, 'yyyyMMdd') AS INT) LEFT JOIN dim_date d_due ON d_due.Date_SK = CAST(FORMAT(ilj.DueDate, 'yyyyMMdd') AS INT) LEFT JOIN dim_vendor vnd ON vnd.Vendor_BK = ilj.VendorCode AND vnd.IsCurrent = 1 LEFT JOIN dim_product prod ON prod.Product_BK = ilj.ItemCode AND prod.IsCurrent = 1 ), -- Final CTE: derive measures, flags, and select target columns final AS ( SELECT InternalInvoiceRef AS Invoice_BK, InvoiceNumber AS Vendor_Invoice_Number, LineNumber AS Invoice_Line_Number, PONumber AS PO_BK, InvoiceDate_SK, ReceivedDate_SK, DueDate_SK, Vendor_SK, Product_SK, InvoiceStatus AS Invoice_Status, MatchStatus AS Match_Status, CASE WHEN MatchStatus = 'Matched' THEN 1 ELSE 0 END AS Is_Match_Passed, CASE WHEN InvoiceStatus = 'Disputed' THEN 1 ELSE 0 END AS Is_Disputed, CASE WHEN InvoiceStatus = 'Paid' THEN 1 ELSE 0 END AS Is_Paid, QuantityBilled AS Quantity_Billed, InvoicedUnitPrice AS Invoiced_Unit_Price, AgreedUnitPrice AS PO_Unit_Price, CAST(QuantityBilled * InvoicedUnitPrice AS DECIMAL(18,2)) AS Invoice_Line_Total, CAST(QuantityBilled * AgreedUnitPrice AS DECIMAL(18,2)) AS PO_Line_Amount, CAST((InvoicedUnitPrice - AgreedUnitPrice) * QuantityBilled AS DECIMAL(18,2)) AS Price_Variance, CASE WHEN AgreedUnitPrice <> 0 THEN CAST(((InvoicedUnitPrice - AgreedUnitPrice) / AgreedUnitPrice) * 100 AS DECIMAL(8,4)) ELSE NULL END AS Price_Variance_Pct, DATEDIFF(DAY, InvoiceDate, DueDate) AS Days_Until_Due, DATEDIFF(DAY, InvoiceDate, ReceivedDate) AS Days_Invoice_To_Receive FROM with_dimension_keys ) SELECT * FROM final"
  }
